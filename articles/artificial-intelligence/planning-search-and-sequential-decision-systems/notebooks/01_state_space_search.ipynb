      "outputs": [],
      "source": [
        "import pandas as pd\n",
        "\n",
        "nodes = pd.DataFrame({\n",
        "    \"node\": [\"A\", \"B\", \"C\", \"D\"],\n",
        "    \"path_cost\": [0, 2, 3, 5],\n",
        "    \"heuristic\": [6, 4, 2, 0]\n",
        "})\n",
        "\n",
        "nodes[\"priority\"] = nodes[\"path_cost\"] + nodes[\"heuristic\"]\n",
        "nodes.sort_values(\"priority\")"
      ]
    }
  ],
