      "source": [
        "import pandas as pd\n",
        "\n",
        "states = pd.DataFrame({\n",
        "    \"state\": [\"s1\", \"s2\", \"s3\"],\n",
        "    \"value_old\": [0.10, 0.35, 0.80],\n",
        "    \"value_new\": [0.18, 0.42, 0.92]\n",
        "})\n",
        "\n",
        "states[\"value_change\"] = (states[\"value_new\"] - states[\"value_old\"]).abs()\n",
        "states"
      ]
    }
