      "source": [
        "# Embedding Geometry"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "rng = np.random.default_rng(42)\n",
        "\n",
        "vectors = rng.normal(size=(10, 8))\n",
        "vectors = vectors / np.linalg.norm(vectors, axis=1, keepdims=True)\n",
        "\n",
        "similarity = vectors @ vectors.T\n",
        "\n",
        "pd.DataFrame(similarity).round(3)"
      ]
    }
  ],
